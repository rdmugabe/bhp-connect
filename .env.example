# ── Required (validated at startup by lib/env.ts) ──────────────────────────
# Use a SEPARATE database for local dev — never point at the production RDS.
DATABASE_URL="postgresql://user:password@localhost:5432/bhp_connect?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-rand-base64-32"

# ── App Configuration ──────────────────────────────────────────────────────
NODE_ENV="development"

# ── AWS S3 (document storage) ──────────────────────────────────────────────
# S3_* take precedence over AWS_* in lib/s3.ts; set whichever pair you use.
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-2"
S3_BUCKET="bhp-connect-documents"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-west-2"
AWS_S3_BUCKET="bhp-connect-documents"

# ── Resend Email Service ───────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="BHP Connect <notifications@yourdomain.com>"

# ── AI (psych-eval extraction) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── Error tracking (optional) ──────────────────────────────────────────────
# When set, register your tracker via lib/logger.ts setErrorSink().
SENTRY_DSN=""
